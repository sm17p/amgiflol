{
	"name": "amgiflol",
	"version": "0.3.4",
	"private": true,
	"description": "Figma-like Layout Inspector For Web",
	"homepage": "https://github.com/sm17p/amgiflol",
	"author": "Sm17p smitp.contact@gmail.com",
	"repository": "https://github.com/sm17p/amgiflol",
	"type": "module",
	"scripts": {
		"build": "wxt build --mv3",
		"build:all": "pnpm build && pnpm build:firefox",
		"build:firefox": "wxt build -b firefox --mv3",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"dev": "wxt --mv3",
		"dev:firefox:mv2": "wxt -b firefox --mv2",
		"dev:firefox": "wxt -b firefox --mv3",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"postinstall": "wxt prepare",
		"test:e2e": "pnpm build && playwright test",
		"wxt": "wxt",
		"zip": "wxt zip",
		"zip:all": "pnpm zip && pnpm zip:firefox",
		"zip:firefox": "wxt zip -b firefox --mv3"
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.17.0",
		"@lucide/svelte": "^0.575.0",
		"@wxt-dev/analytics": "0.5.4"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@playwright/test": "^1.58.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.3.0",
		"@unocss/extractor-svelte": "^66.6.0",
		"@unocss/preset-attributify": "^66.6.0",
		"@unocss/preset-rem-to-px": "^66.6.0",
		"@unocss/preset-wind4": "^66.6.0",
		"@wxt-dev/auto-icons": "^1.1.1",
		"@wxt-dev/module-svelte": "^2.0.4",
		"@wxt-dev/unocss": "^1.0.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"oxlint-tsgolint": "^0.14.2",
		"playwright": "^1.58.2",
		"playwright-webextext": "^0.0.4",
		"runed": "^0.37.1",
		"svelte": "^5.53.3",
		"svelte-check": "^4.4.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"unocss": "^66.6.0",
		"wxt": "^0.20.18"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
